# Campus network account settings. Keep real values in .env only.
FUDAN_NET_USERNAME=
FUDAN_NET_PASSWORD=

# Campus network portal and target network channel.
FUDAN_NET_BASE_URL=http://10.102.250.36
FUDAN_NET_CHANNEL_NAME=校园网

# Poll interval in seconds.
FUDAN_NET_INTERVAL=5

# Per-target external connectivity timeout in seconds.
FUDAN_NET_CHECK_TIMEOUT=3

# Comma-separated external URLs used to verify real internet connectivity.
FUDAN_NET_CHECK_URLS=http://connect.rom.miui.com/generate_204,https://www.baidu.com,https://www.qq.com
